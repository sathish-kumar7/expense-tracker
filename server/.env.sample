# Postgres connection string used by the server (src/index.ts).
# Format: postgres://<user>:<password>@<host>:<port>/<database>
# Defaults below match server/database.json (used by db-migrate).
DATABASE_URL=postgres://postgres:Password@localhost:5432/expense_db

# Port the Express server listens on (defaults to 4000 if unset).
PORT=4000
